# ~~~~~~~~~~~~~~~ History ~~~~~~~~~~~~~~~~~~~~~~~~
HISTFILE="$HOME/.zsh_history"
HISTSIZE=100000
SAVEHIST=100000

# ~~~~~~~~~~~~~~~ Mise ~~~~~~~~~~~~~~~~~~~~~~~~
if command -v mise > /dev/null ; then
  eval "$(mise activate zsh)"
fi

# ~~~~~~~~~~~~~~~ Prompt ~~~~~~~~~~~~~~~~~~~~~~~~
PURE_GIT_PULL=0
fpath+=($HOME/.zsh/pure)
autoload -U promptinit; promptinit
prompt pure

# enable zsh vi-mode
bindkey -v
export KEYTIMEOUT=1
